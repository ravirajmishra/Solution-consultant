<script>
const D={ind:'',bud:'',pains:[],rev:'',emp:'',geo:'',ctype:'',tech:'',chall:'',btype:'',tline:'',constr:''};
let cur=1;

function show(id){
  ['landing','wizard','processing','dashboard'].forEach(x=>{
    const e=document.getElementById(x);if(!e)return;e.style.display='none';
  });
  const el=document.getElementById(id);if(!el)return;
  el.style.display=(id==='processing')?'flex':'block';
}
window.addEventListener('load',()=>show('landing'));
function startWiz(){show('wizard');setS(1);}
function goBack(){cur===1?show('landing'):setS(cur-1);}
function setS(n){
  cur=n;
  document.querySelectorAll('.step').forEach((s,i)=>s.classList.toggle('active',i+1===n));
  for(let i=1;i<=4;i++){
    const d=document.getElementById('sp'+i);if(!d)continue;
    d.classList.remove('active','done');d.style.width='16px';
    if(i<n)d.classList.add('done');
    else if(i===n){d.classList.add('active');d.style.width='28px';}
  }
  document.getElementById('wlbl').textContent='Step '+n+' of 4';
}
function selI(el,v){document.querySelectorAll('.ic').forEach(c=>c.classList.remove('sel'));el.classList.add('sel');D.ind=v;document.getElementById('oiw').style.display=v==='Other'?'block':'none';}
function selB(el,v){document.querySelectorAll('.bc').forEach(c=>c.classList.remove('sel'));el.classList.add('sel');D.bud=v;}
function togP(el,v){el.classList.toggle('sel');D.pains=D.pains.includes(v)?D.pains.filter(p=>p!==v):[...D.pains,v];}
function nxt(n){
  if(cur===1&&!D.ind){alert('Please select your industry.');return;}
  if(cur===2){
    D.rev=document.getElementById('rev').value;D.emp=document.getElementById('emp').value;
    D.geo=document.getElementById('geo').value;D.ctype=document.getElementById('ctype').value;
    D.tech=document.getElementById('tech').value;D.chall=document.getElementById('chall').value;
    if(!D.rev||!D.emp){alert('Please fill in revenue and employee count.');return;}
  }
  if(cur===3){
    D.btype=document.getElementById('btype').value;D.tline=document.getElementById('tline').value;
    D.constr=document.getElementById('constr').value;
    if(!D.bud){alert('Please select a budget range.');return;}
  }
  setS(n);
}

// All API calls go through /api/analyze — no CORS issues
async function callAPI(type, prompt){
  const r=await fetch('/api/analyze',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({type,payload:{prompt}})
  });
  if(!r.ok){const e=await r.json();throw new Error(e.error||'Server error '+r.status);}
  return r.json();
}

async function run(){
  D.pains=[...document.querySelectorAll('.pi.sel')].map(e=>e.textContent.trim());
  if(!D.pains.length){const e=document.getElementById('erbox');e.style.display='block';e.textContent='Please select at least one pain point.';return;}
  D.rev=document.getElementById('rev').value;D.emp=document.getElementById('emp').value;
  D.geo=document.getElementById('geo').value;D.ctype=document.getElementById('ctype').value;
  D.tech=document.getElementById('tech').value;D.chall=document.getElementById('chall').value;
  D.btype=document.getElementById('btype').value;D.tline=document.getElementById('tline').value;
  D.constr=document.getElementById('constr').value;
  const ind=D.ind==='Other'?(document.getElementById('otherI').value||'Other'):D.ind;
  show('processing');
  const steps=['ps1','ps2','ps3','ps4','ps5','ps6'];let si=0;
  const tick=()=>{if(si>0)document.getElementById(steps[si-1]).classList.add('done');if(si<steps.length){document.getElementById(steps[si]).classList.add('active');si++;setTimeout(tick,700+Math.random()*600);}};tick();

  try{
    document.getElementById('ptit').textContent='Searching Real-World Data';
    const rp=`You are an enterprise business intelligence researcher with Google Search access.

Research this company's situation and find real, verified information:

COMPANY: ${ind} | Revenue: ${D.rev||'unknown'} | Employees: ${D.emp||'unknown'} | Region: ${D.geo||'unspecified'} | Type: ${D.ctype||'private'} | Existing tech: ${D.tech||'unspecified'} | Budget: ${D.bud} | Timeline: ${D.tline} | Constraints: ${D.constr||'none'} | Challenge: ${D.chall||'general efficiency'} | Pain points: ${D.pains.join(', ')}

Search for each of these:
1. REAL CASE STUDIES: Find 2-3 actual named companies in ${ind} that solved similar pain points. Include company name, vendor/technology used, investment amount, measured ROI, year of deployment. Look for press releases and vendor case study pages.
2. INDUSTRY BENCHMARKS: Current ${ind} benchmarks from industry associations, consulting reports, or trade publications — efficiency rates, cost metrics, downtime rates.
3. COMPETITORS: Which ${ind} companies recently deployed optimization initiatives, and what competitive advantage they gained.
4. VENDOR PRICING: Actual pricing ranges for solutions within ${D.bud} budget for ${ind}.
5. NON-TECH WINS: Documented cases where ${ind} companies achieved ROI through operational/process/training changes — not just technology.

Be specific: real company names, real dollar figures, real percentages. Note if data is estimated.`;

    const research=await callAPI('research',rp);

    document.getElementById('ptit').textContent='Building Executive Report';
    document.getElementById('psub').textContent='Structuring findings into 8-persona analysis';

    const sp=`Based on this verified research about ${ind}:

${research.text}

COMPANY CONTEXT: Revenue ${D.rev} | Employees ${D.emp} | Region ${D.geo} | Budget ${D.bud} (${D.btype}) | Timeline ${D.tline} | Constraints: ${D.constr||'none'} | Existing tech: ${D.tech||'unspecified'} | Challenge: ${D.chall||'general'} | Pains: ${D.pains.join(', ')}

Generate a comprehensive enterprise solution using the research above. Use real data found; supplement with known industry benchmarks where needed (label as "benchmark").

Return a single JSON object with these exact keys:
{
  "solution_title": "string",
  "solution_type": "Technical or Operational or Non-Technical or Environmental or Hybrid",
  "problem_diagnosis": "string",
  "proof_cases": [{"company":"string","industry":"string","year":"string","situation":"string","solution":"string","vendor":"string","investment":"string","outcome":"string","roi":"string","timeframe":"string"}],
  "competitor_benchmark": [{"name":"string","status":"deployed or exploring or behind","detail":"string"}],
  "budget": {"total_min":"string","total_max":"string","capex_portion":"string","opex_annual":"string","payback_months":18,"npv_3yr":"string","irr":"string","phase1_cost":"string","phase1_desc":"string","phase2_cost":"string","phase2_desc":"string","financing_note":"string"},
  "kpis": [{"name":"string","before":"string","after":"string","unit":"string","benchmark":"string"}],
  "personas": {
    "ceo": {"headline":"string","key_message":"string","metrics":[{"label":"string","value":"string","context":"string"}],"board_narrative":"string","risk_of_inaction":"string"},
    "cfo": {"headline":"string","key_message":"string","metrics":[{"label":"string","value":"string","context":"string"}],"financing_options":["string"],"tax_note":"string","risk_note":"string"},
    "coo": {"headline":"string","key_message":"string","metrics":[{"label":"string","value":"string","context":"string"}],"process_changes":["string"],"headcount_impact":"string","complexity":"Low or Medium or High"},
    "cto": {"headline":"string","key_message":"string","metrics":[{"label":"string","value":"string","context":"string"}],"tech_requirements":["string"],"integration_note":"string","build_buy":"string","risks":["string"]},
    "cmo": {"headline":"string","key_message":"string","metrics":[{"label":"string","value":"string","context":"string"}],"customer_impact":"string","revenue_attribution":"string"},
    "domain_expert": {"headline":"string","key_message":"string","metrics":[{"label":"string","value":"string","context":"string"}],"compliance_impact":"string","professional_note":"string"}
  },
  "roadmap": [{"phase":"string","duration":"string","title":"string","actions":["string"],"milestone":"string"}]
}`;

    const result=await callAPI('structure',sp);
    render(result,ind,research.queries||[]);

  }catch(err){
    console.error(err);show('wizard');setS(4);
    const e=document.getElementById('erbox');e.style.display='block';
    e.textContent='Error: '+err.message+'. Check that GEMINI_API_KEY is set in Vercel environment variables.';
  }
}

function bc(t){return({'Technical':'btc','Operational':'bop','Non-Technical':'bnt','Environmental':'ben','Hybrid':'bhy'}[t]||'bin');}

function render(r,ind,queries){
  document.getElementById('dmeta').textContent=`${ind.toUpperCase()} · ${D.bud} · ${new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}).toUpperCase()}`;
  document.getElementById('sbadges').innerHTML=`<span class="bpill bin">${ind}</span><span class="bpill ${bc(r.solution_type)}">${r.solution_type||'Hybrid'}</span><span class="bpill bin">${D.bud}</span><span class="bpill bin">${D.tline||'6–12 months'}</span>`;
  document.getElementById('stitle').textContent=r.solution_title||'—';
  document.getElementById('sdiag').textContent=r.problem_diagnosis||'—';

  let ph='';
  (r.proof_cases||[]).slice(0,2).forEach(c=>{
    ph+=`<div class="proofbox"><div class="pco">${c.company} <span style="color:var(--tx3);font-weight:400;font-size:11px">${c.year} · ${c.industry}</span></div><div class="pmeta">via ${c.vendor}</div><div class="ptxt">${c.situation} ${c.solution}</div><div class="pnums"><div class="pnum"><div class="pnv">${c.roi}</div><div class="pnl">ROI / Payback</div></div><div class="pnum"><div class="pnv">${c.timeframe}</div><div class="pnl">Time to result</div></div><div class="pnum"><div class="pnv">${c.investment}</div><div class="pnl">Investment</div></div></div></div>`;
  });
  document.getElementById('proofwrap').innerHTML=ph||'<p style="color:var(--tx3);font-size:13px">No case studies found for this profile.</p>';

  const b=r.budget||{};
  document.getElementById('budwrap').innerHTML=`
    <div class="brow"><span class="bk">Investment range</span><span class="bv">${b.total_min} – ${b.total_max}</span></div>
    <div class="brow"><span class="bk">CapEx portion</span><span class="bv">${b.capex_portion||'—'}</span></div>
    <div class="brow"><span class="bk">Annual OpEx</span><span class="bv">${b.opex_annual||'—'}</span></div>
    <div class="brow"><span class="bk">Payback period</span><span class="bv">${b.payback_months} months</span></div>
    <div class="brow"><span class="bk">3-Year NPV</span><span class="bv">${b.npv_3yr||'—'}</span></div>
    <div class="brow"><span class="bk">IRR</span><span class="bv">${b.irr||'—'}</span></div>
    <div class="brow"><span class="bk">Phase 1</span><span class="bv" style="font-size:12px">${b.phase1_cost} — ${b.phase1_desc||''}</span></div>
    <div class="brow"><span class="bk">Phase 2</span><span class="bv" style="font-size:12px">${b.phase2_cost} — ${b.phase2_desc||''}</span></div>
    <div class="fnote">${b.financing_note||''}</div>`;

  let kh='';
  (r.kpis||[]).slice(0,5).forEach(k=>{
    kh+=`<div class="krow"><div class="karr">↑</div><div style="flex:1"><div style="font-size:13px">${k.name}</div><div style="font-size:11px;color:var(--tx3)">${k.before} → <strong style="color:var(--gr)">${k.after}</strong> ${k.unit} · Top: ${k.benchmark}</div></div></div>`;
  });
  document.getElementById('kpiwrap').innerHTML=kh;

  let ch='';
  (r.competitor_benchmark||[]).slice(0,4).forEach((c,i)=>{
    const sc=c.status==='deployed'?'sp-d':c.status==='exploring'?'sp-e':'sp-b';
    ch+=`<div class="crow"><div style="font-size:11px;color:var(--tx3);width:20px">#${i+1}</div><div style="flex:1"><div style="font-size:13px;font-weight:500">${c.name}</div><div style="font-size:11px;color:var(--tx3)">${c.detail}</div></div><span class="spill ${sc}">${c.status}</span></div>`;
  });
  document.getElementById('compwrap').innerHTML=ch;

  const ps=[{k:'ceo',l:'CEO'},{k:'cfo',l:'CFO'},{k:'coo',l:'COO'},{k:'cto',l:'CTO'},{k:'cmo',l:'CMO'},{k:'domain_expert',l:'Domain Expert'}];
  let tabs='',panels='';
  ps.forEach((p,i)=>{
    const pd=(r.personas||{})[p.k];if(!pd)return;
    tabs+=`<div class="ptab${i===0?' active':''}" id="ptab-${p.k}" onclick="swP('${p.k}')">${p.l}</div>`;
    let mx='';(pd.metrics||[]).slice(0,3).forEach(m=>{mx+=`<div class="mbox"><div class="mlbl">${m.label}</div><div class="mv">${m.value}</div><div class="mc">${m.context||''}</div></div>`;});
    let ex='';
    if(p.k==='cfo'){
      ex+=`<div style="margin-top:14px"><div class="fl" style="margin-bottom:8px">Financing options</div><div class="dpills">${(pd.financing_options||[]).map(f=>`<span class="dpill">${f}</span>`).join('')}</div></div>`;
      if(pd.tax_note)ex+=`<div class="ib"><strong>Tax note:</strong> ${pd.tax_note}</div>`;
      if(pd.risk_note)ex+=`<div class="wb2"><strong>Risk of delay:</strong> ${pd.risk_note}</div>`;
    }
    if(p.k==='coo'){
      ex+=`<div style="margin-top:14px"><div class="fl" style="margin-bottom:8px">Process changes required</div><ul class="lp">${(pd.process_changes||[]).map(c=>`<li>${c}</li>`).join('')}</ul></div>`;
      ex+=`<div style="display:flex;gap:12px;margin-top:12px"><div class="ib" style="flex:1"><strong>Workforce impact:</strong> ${pd.headcount_impact||'—'}</div><div class="ib" style="min-width:110px;text-align:center"><div style="font-size:10px;color:var(--tx3);margin-bottom:4px">Complexity</div><div style="font-size:16px;font-weight:700;color:${pd.complexity==='Low'?'var(--gr)':pd.complexity==='High'?'var(--rd)':'var(--am)'}">${pd.complexity}</div></div></div>`;
    }
    if(p.k==='cto'){
      ex+=`<div style="margin-top:14px"><div class="fl" style="margin-bottom:8px">Technical requirements</div><ul class="lp">${(pd.tech_requirements||[]).map(c=>`<li>${c}</li>`).join('')}</ul></div>`;
      ex+=`<div class="ib"><strong>Build vs Buy:</strong> ${pd.build_buy||'—'}</div>`;
      if((pd.risks||[]).length)ex+=`<div class="wb2"><strong>Key risks:</strong> ${pd.risks.join(' · ')}</div>`;
    }
    if(p.k==='cmo'){
      if(pd.customer_impact)ex+=`<div class="ib"><strong>Customer impact:</strong> ${pd.customer_impact}</div>`;
      if(pd.revenue_attribution)ex+=`<div class="ib" style="margin-top:8px"><strong>Revenue attribution:</strong> ${pd.revenue_attribution}</div>`;
    }
    if(p.k==='domain_expert'){
      if(pd.compliance_impact)ex+=`<div class="ib"><strong>Compliance:</strong> ${pd.compliance_impact}</div>`;
      if(pd.professional_note)ex+=`<div class="wb2"><strong>Professional note:</strong> ${pd.professional_note}</div>`;
    }
    const bn=p.k==='ceo'&&pd.board_narrative?`<div class="ib" style="margin-top:12px;font-style:italic">"${pd.board_narrative}"</div>`:'';
    const ri=p.k==='ceo'&&pd.risk_of_inaction?`<div class="wb2"><strong>Risk of inaction:</strong> ${pd.risk_of_inaction}</div>`:'';
    panels+=`<div class="ppanel${i===0?' active':''}" id="ppanel-${p.k}"><div class="phero"><div class="prole">${p.l} VIEW</div><div class="phl">${pd.headline||'—'}</div><div class="pmsg">${pd.key_message||'—'}</div><div class="mr">${mx}</div></div>${ex}${bn}${ri}</div>`;
  });
  document.getElementById('ptabs').innerHTML=tabs;
  document.getElementById('ppanels').innerHTML=panels;

  let rh='';
  (r.roadmap||[]).forEach(p=>{
    rh+=`<div class="rphase"><div class="rl"><div class="rdot"></div><div class="rline"></div></div><div class="rcont"><div class="rpl">${p.phase} · ${p.duration}</div><div class="rti">${p.title}</div><div class="ra">${(p.actions||[]).join(' · ')}</div><span class="rmil">✓ ${p.milestone}</span></div></div>`;
  });
  document.getElementById('rmwrap').innerHTML=rh;

  if(queries.length){
    const sw=document.getElementById('srcrow');sw.style.display='flex';
    queries.slice(0,6).forEach(q=>{const c=document.createElement('span');c.className='srchip';c.textContent=q;sw.appendChild(c);});
  }
  show('dashboard');
}

function swP(k){
  document.querySelectorAll('.ptab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.ppanel').forEach(p=>p.classList.remove('active'));
  const t=document.getElementById('ptab-'+k),p=document.getElementById('ppanel-'+k);
  if(t)t.classList.add('active');if(p)p.classList.add('active');
}
</script>
</body>
</html>
